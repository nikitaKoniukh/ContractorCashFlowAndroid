<?xml version="1.0" encoding="utf-8"?><!--
   Backup rules for KablanPro.
   Exclude DataStore and SharedPreferences so a reinstall starts with
   the correct defaults (Hebrew / ILS) instead of restoring stale data.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="file" path="datastore/"/>
</full-backup-content>